{
	"info": {
		"_postman_id": "c1f7a078-43d9-4b68-b788-b2a632128a1c",
		"name": "Carrpigeo API",
		"description": "Collection of API requests to test the Carrpigeo notification/email sending service.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"Database status is up\", function () {",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.status).to.eql(\"up\");",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/health",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"health"
					]
				},
				"description": "Retrieves the health status of the database and application connection."
			},
			"response": []
		},
		{
			"name": "Send Email",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 202 (Accepted)\", function () {",
							"    pm.response.to.have.status(202);",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"to\": \"recipient@example.com\",\n  \"subject\": \"Test Email from Carrpigeo\",\n  \"body\": \"Hello! This is a test email sent using the Carrpigeo Postman collection.\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/send/email",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"send",
						"email"
					]
				},
				"description": "Sends an email message via Carrpigeo's email service."
			},
			"response": []
		},
		{
			"name": "Send Email with Template",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 202 (Accepted)\", function () {",
							"    pm.response.to.have.status(202);",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"to\": \"recipient@example.com\",\n  \"subject\": \"Welcome!\",\n  \"template_id\": \"YOUR_TEMPLATE_ID\",\n  \"data\": {\n    \"Name\": \"John Doe\",\n    \"PromoCode\": \"WELCOME2026\"\n  }\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/send/email/template",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"send",
						"email",
						"template"
					]
				},
				"description": "Sends an email using a registered HTML template and dynamic variable substitution."
			},
			"response": []
		},
		{
			"name": "Create HTML Template",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 202 (Accepted)\", function () {",
							"    pm.response.to.have.status(202);",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "name",
							"value": "Welcome Template",
							"type": "text"
						},
						{
							"key": "file",
							"description": "HTML file of the template containing placeholders like {{.Name}}",
							"type": "file",
							"src": []
						}
					]
				},
				"url": {
					"raw": "{{baseUrl}}/templates",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"templates"
					]
				},
				"description": "Uploads and saves a new HTML email template."
			},
			"response": []
		},
		{
			"name": "Delete HTML Template",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "DELETE",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/templates?id=YOUR_TEMPLATE_ID",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"templates"
					],
					"query": [
						{
							"key": "id",
							"value": "YOUR_TEMPLATE_ID"
						}
					]
				},
				"description": "Deletes an HTML email template by its ID."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:2500",
			"type": "string"
		}
	]
}